{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URS/DUX Audit Report",
  "version": "1.2.0",
  "type": "object",
  "required": ["urs_version", "dux_version", "audit_type", "status", "generated_utc", "summary"],
  "properties": {
    "urs_version":  { "type": "string" },
    "dux_version":  { "type": "string" },
    "audit_type":   { "type": "string", "enum": ["full", "incremental", "targeted"] },
    "status":       { "type": "string", "enum": ["PASS", "FAIL", "WARN"] },
    "generated_utc":{ "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["total_checks", "passed", "failed", "warnings"],
      "properties": {
        "total_checks": { "type": "integer", "minimum": 0 },
        "passed":       { "type": "integer", "minimum": 0 },
        "failed":       { "type": "integer", "minimum": 0 },
        "warnings":     { "type": "integer", "minimum": 0 }
      }
    }
  }
}
